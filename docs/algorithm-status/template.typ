// Algorithm Status Table: Template
// Provides the `algorithm-status-table` function used by main.typ.
// Do not edit this file to add/remove algorithms; edit main.typ instead.

// ---------------------------------------------------------------------------
// Cell renderer: compact bullet list (or "-" when empty).
// ---------------------------------------------------------------------------
#let algo-cell(items) = {
  if items.len() == 0 {
    align(center + horizon, text(fill: luma(160), style: "italic")[-])
  } else {
    pad(x: 4pt, y: 4pt,
      for item in items {
        block(spacing: 2.5pt)[- #item]
      }
    )
  }
}

// ---------------------------------------------------------------------------
// Main table function.
//
// Parameters:
//   title: document title (content)
//   footnotes: content shown below the title (e.g. legend)
//   categories: array of column header strings
//   status-rows: array of dicts, each with:
//       label: content: row header (e.g. [*Finished*])
//       cells: ((...), (...), ...): one tuple of content items per category
// ---------------------------------------------------------------------------
#let algorithm-status-table(
  title: [dfbench: Algorithm Implementation Status],
  footnotes: [],
  categories: (),
  status-rows: (),
) = {
  set page(width: auto, height: auto, margin: 1cm, flipped: true)
  set text(font: "New Computer Modern", size: 8pt)

  // Title block
  align(center)[
    #text(size: 14pt, weight: "bold")[#title]
    #v(4pt)
    #text(size: 9pt, fill: luma(100))[#footnotes]
  ]

  v(8pt)

  // Compute column widths: auto for the label, then a reasonable min per category.
  let cat-width = 12em
  let col-widths = (auto,) + categories.map(_ => cat-width)

  // Main table
  table(
    columns: col-widths,
    align: (col, _) => if col == 0 { horizon + center } else { left + top },
    stroke: 0.5pt + luma(180),
    inset: 0pt,
    column-gutter: 0pt,

    // Header
    table.header(
      table.cell(fill: luma(230), pad(6pt)[]),
      ..categories.map(c =>
        table.cell(fill: luma(230), pad(6pt, text(weight: "bold", size: 8.5pt, c)))
      ),
    ),

    // Data rows
    ..status-rows.map(row => (
      table.cell(
        fill: luma(245),
        pad(x: 8pt, y: 6pt, row.label),
      ),
      ..row.cells.map(items => algo-cell(items)),
    )).flatten(),
  )

  v(10pt)

  // Summary counts
  {
    let count(cells) = cells.map(c => c.len()).sum()

    let headers = status-rows.map(r => r.label)
    let counts  = status-rows.map(r => count(r.cells))

    align(center, table(
      columns: (auto,) + headers.map(_ => auto),
      align: center,
      stroke: 0.5pt + luma(180),

      table.header(
        table.cell(fill: luma(230), pad(6pt)[]),
        ..headers.map(h =>
          table.cell(fill: luma(230), pad(6pt, h))
        ),
      ),

      pad(6pt)[*Count*],
      ..counts.map(n => pad(6pt)[#n]),
    ))
  }
}
